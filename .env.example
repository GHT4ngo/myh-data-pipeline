PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=data_pipeline_de25
PG_USER=postgres
PG_PASSWORD=your_password_here

# Optional: SSL mode for the database connection.
# Local dev defaults to "prefer"; cloud (Neon etc.) defaults to "require".
PG_SSLMODE=

# Optional: comma-separated allow-list for CORS.
# Leave empty to allow all origins (handy for local development).
ALLOWED_ORIGINS=

# Optional: shared secret required in the X-Refresh-Token header for POST /refresh.
# Leave empty to disable the guard (and the operational endpoint becomes open).
REFRESH_SECRET=
